# Database (PostgreSQL — required for Vercel; use Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/deadegos?sslmode=require"

# Admin portal
ADMIN_PASSWORD="200Orders!"
